
/* Entry point symbol */
ENTRY(_start)

SECTIONS
{
    /* Define where we want the kernel to live */
    /* Limine maps physical 0x200000 at virtual 0xFFFFFFFF80000000 */
    KERNEL_VMA = 0xFFFFFFFF80000000;
    KERNEL_LMA = 0x200000;   /* physical load address (2 MiB) */

    . = KERNEL_VMA;

    .text : AT(KERNEL_LMA) ALIGN(4K)
    {
        KEEP(*(.text._start))
        *(.text .text.*)
    }

    .rodata : AT(ADDR(.rodata) - KERNEL_VMA + KERNEL_LMA) ALIGN(4K)
    {
        *(.rodata .rodata.*)
    }

    .data : AT(ADDR(.data) - KERNEL_VMA + KERNEL_LMA) ALIGN(4K)
    {
        *(.data .data.*)
    }

    .bss : AT(ADDR(.bss) - KERNEL_VMA + KERNEL_LMA) ALIGN(4K)
    {
        __bss_start = .;
        *(.bss .bss.* COMMON)
        __bss_end = .;
    }


    /DISCARD/ : {
        *(.comment)
        *(.note)
        *(.eh_frame)
    }


    .debug_info     0 (INFO) : { *(.debug_info*) }
    .debug_abbrev   0 (INFO) : { *(.debug_abbrev*) }
    .debug_loc      0 (INFO) : { *(.debug_loc*) }
    .debug_macinfo  0 (INFO) : { *(.debug_macinfo*) }
    .debug_pubnames 0 (INFO) : { *(.debug_pubnames*) }
    .debug_pubtypes 0 (INFO) : { *(.debug_pubtypes*) }
    .debug_str      0 (INFO) : { *(.debug_str*) }
    .debug_ranges   0 (INFO) : { *(.debug_ranges*) }
    .debug_line     0 (INFO) : { *(.debug_line*) }
    .debug_aranges  0 (INFO) : { *(.debug_aranges*) }
    .debug_frame    0 (INFO) : { *(.debug_frame*) }    
    
}
